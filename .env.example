# Local development environment
# Copy this file to .env and fill in your own values. Never commit real secrets.

# Supabase (chat session store, replaces MongoDB) — via Data API + secret key
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SECRET_KEY=your_supabase_secret_key
SUPABASE_PUBLISHABLE_KEY=your_supabase_publishable_key
SUPABASE_JWKS_URL=https://your-project.supabase.co/auth/v1/.well-known/jwks.json

# Legacy MongoDB (no longer used)
MONGODB_URL=your_mongodb_connection_string

# AI provider keys (add your own to enable real chat responses)
GEMINI_API_KEY=your_gemini_api_key
GOOGLE_AI_GENERATIVE=your_google_ai_api_key
GROQ_API_KEY=your_groq_api_key
TAVILY_API_KEY=your_tavily_api_key
XAI_API_KEY=your_xai_api_key

# Langfuse (optional)
LANGFUSE_SECRET_KEY=your_langfuse_secret_key
LANGFUSE_PUBLIC_KEY=your_langfuse_public_key
LANGFUSE_HOST=https://cloud.langfuse.com

# Tenant defaults
DEFAULT_TENANT=default
TENANT_ISOLATION_ENABLED=true
